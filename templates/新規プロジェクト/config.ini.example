; =====================================================
; このファイルを config.ini にコピーして、実際の値を書き換えてください。
;   コピー方法: このファイルを複製して名前を config.ini に変える
;
; ルール:
;   - セクション名・キー名は大文字で書く（Python 側の config.SECTION.KEY と一致させる）
;   - 機密情報（パスワード・トークン・メールアドレス等）はここに書かない
;     → 認証情報の登録.bat（python -m comken.credentials）で暗号化して登録する
;   - config.ini は .gitignore 済み（git に上がらない）。このテンプレートだけ git に含める
; =====================================================

[CREDENTIALS]
; どのサービス名で登録した認証情報を使うか（キー名そのものは機密ではない）
; 例: SALESFORCE = salesforce  →  salesforce_username / salesforce_password を使う
; SALESFORCE = salesforce

[FILES]
; 入力ファイルの場所など（環境によって変わる非機密の値）
; INPUT_CSV = C:\作業\input\data.csv

[REPORT]
; 出力先はローカルにする（NAS は読み込み元・置き場であり、新規出力先にはしない）
OUTPUT_FOLDER = C:\作業\reports

[BROWSER]
; ブラウザ自動操作を使う場合。HEADLESS = True で画面を出さずに動かす
; HEADLESS = False
