; =====================================================
; このファイルを config.ini にコピーして値を書き換えてください。
; セクション名・キー名は大文字で書く（Python 側の config.SECTION.KEY と一致する）
; 認証情報・個人情報はここに書かず python -m comken.credentials で登録する
; =====================================================

[CREDENTIALS]
; どのプレフィックスで登録した認証情報を使うか（キー名は機密ではない）。
; salesforce_test に変えるだけで全項目がテスト用に切り替わる
SALESFORCE = salesforce

[SALESFORCE]
; 組織の My Domain の URL（非機密）。client_id / client_secret は credentials に登録する
DOMAIN_URL = https://your-domain.my.salesforce.com

[REPORT]
OUTPUT_FOLDER = C:\Users\Public\Downloads
