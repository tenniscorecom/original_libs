; =====================================================
; このファイルを config.ini にコピーして値を書き換えてください。
; セクション名・キー名は大文字で書く（Python 側の config.SECTION.KEY と一致する）
; 認証情報・個人情報はここに書かず python -m comken.credentials で登録する
; =====================================================

[FILES]
; 今日の日付が名前に入った CSV（例: 20260713_売上.csv）を置くフォルダ
INPUT_FOLDER = C:\作業\input

[REPORT]
; 出力先はローカルにする（NAS は読み込み元・モジュール置き場。新規出力先にはしない）
OUTPUT_FOLDER = C:\作業\reports
